# Storylock environment template
#
# Copy this file to `.env` at the repo root for backend settings.
# Copy the frontend block at the bottom into `app/.env.local`.
#
# Demo mode:
# - Leave SOLANA_LISTENER_ENABLED=false to run the incomplete version
# - This lets the UI and backend run without a local validator

# ── Solana / backend runtime ───────────────────────────────────────────────────
SOLANA_CLUSTER=localnet
SOLANA_RPC=http://127.0.0.1:8899
PROGRAM_ID=ahWw6JRQVTsE5NQoEJC7kXcE5ZYU3KZS6jEU9V7mx15
SOLANA_LISTENER_ENABLED=false

# To use a real Solana environment later:
# SOLANA_CLUSTER=devnet
# SOLANA_RPC=https://api.devnet.solana.com
# SOLANA_LISTENER_ENABLED=true

# ── Backend server ─────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Optional AI features ───────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ElevenLabs narration for creator story playback
ELEVENLABS_API_KEY=
# Example: voice ID from your ElevenLabs dashboard
ELEVENLABS_VOICE_ID=
# Optional; defaults to eleven_multilingual_v2
ELEVENLABS_MODEL_ID=

# ── Optional production-only storage ───────────────────────────────────────────
# ARWEAVE_WALLET_JSON=<path to arweave wallet JSON>

# ── Frontend (copy into app/.env.local) ───────────────────────────────────────
# VITE_SOLANA_NETWORK=localnet
# VITE_RPC_ENDPOINT=http://127.0.0.1:8899
# VITE_PROGRAM_ID=ahWw6JRQVTsE5NQoEJC7kXcE5ZYU3KZS6jEU9V7mx15
# VITE_BACKEND_URL=http://localhost:4000
